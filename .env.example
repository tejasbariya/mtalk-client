# ─── Client Environment ───────────────────────────────────────────────────────
# This file is READ BY VITE at build time.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# DO NOT put secrets here — this is bundled into the client JS.

# ── API URL ──────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT:
#   VITE_API_URL=http://localhost:5000

# PRODUCTION (Render backend):
#   1. Go to https://render.com → your backend service → Settings → copy the URL
#   2. Paste it below (no trailing slash)
VITE_API_URL=https://your-backend-name.onrender.com
